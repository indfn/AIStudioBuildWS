# (Required) The unified target URL that all browser instances will visit
CAMOUFOX_INSTANCE_URL=""

# (Optional) Browser run mode. Defaults to "virtual".
# Optional values:
#   - "true": Fully headless mode, no graphical interface.
#   - "false": Normal mode, will display browser window.
#   - "virtual": Virtual display mode, simulates a display in a headless environment, best compatibility.
# CAMOUFOX_HEADLESS="virtual"

# (Optional) Set proxy server. If proxy is not needed, comment out this line or leave it empty.
# Format: http://<user>:<password>@<host>:<port> or http://<host>:<port>
# CAMOUFOX_PROXY="http://proxy.example.com:8080"

# (Optional) Delay time (seconds) between starting each browser instance, defaults to 30 seconds.
# Increasing this value can reduce CPU peak load when starting multiple instances.
INSTANCE_START_DELAY=30

# (Optional) Maximum retry count for KeepAliveError, defaults to 5 times.
# After reaching the limit, the instance will stop restarting and exit to avoid resource consumption from frequent restarts.
MAX_RESTART_RETRIES=5

# (Optional) Log timezone offset (hours). Defaults to 8 (UTC+8 Beijing time).
# Set to 0 for UTC time.
TZ_OFFSET=8

# (Optional) Project root directory path. Usually does not need manual setting, the program will detect it automatically.
# Only needed in specific container environments or custom deployment structures.
# CAMOUFOX_PROJECT_ROOT="/app"

# (Optional) Running mode.
# If set to "true", the program will run in Web Server mode (providing health check endpoints), suitable for HuggingFace Spaces.
# If not set or set to other values, the program will run in standalone CLI mode.
HG="false"

# (Optional) Authentication refresh interval range (in hours).
# The program will pick a random time within this range to reload the page and save fresh cookies.
# Default is every 6 to 9 hours to stay ahead of the estimated 16-24h session expiration.
REFRESH_INTERVAL_MIN=6
REFRESH_INTERVAL_MAX=9

# (Optional) Maximum time (in milliseconds) to wait for a generation to finish before forcing a refresh.
# Defaults to 300000 (5 minutes).
SPINNER_TIMEOUT_MS=300000

# (Required/Optional) User Cookie configuration.
# At least one valid Cookie source needs to be configured (environment variable or JSON file under cookies/ directory).
# Supports configuring multiple accounts, distinguished by suffix number: _1, _2, _3 ...
# Value can be a JSON string (Cookie-Editor export format) or KV string ("name=value; name2=value2").
# USER_COOKIE_1='[{"name": "__Secure-1PSID", "value": "..."}]'
# USER_COOKIE_2='__Secure-1PSID=...; __Secure-1PAPISID=...'
